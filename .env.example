# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=reelz
POSTGRES_PASSWORD=reelzpassword
POSTGRES_DB=reelz

# Full connection string used by Prisma (auto-built from above in Docker Compose)
DATABASE_URL=postgresql://reelz:reelzpassword@localhost:5432/reelz

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme-super-secret-jwt
JWT_REFRESH_SECRET=changeme-super-secret-refresh

# ─── TMDB ─────────────────────────────────────────────────────────────────────
# Get your free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
